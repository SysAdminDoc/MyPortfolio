<UserControl x:Class="MyPortfolio.Chrome.Views.ExtensionCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MyPortfolio.Converters"
             xmlns:vm="clr-namespace:MyPortfolio.Chrome.ViewModels"
             d:DataContext="{d:DesignInstance vm:ExtensionCardViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="378" Height="286">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </UserControl.Resources>

    <Border Style="{StaticResource CardBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="52" Height="52" CornerRadius="8"
                        Background="{StaticResource Surface0Brush}"
                        BorderBrush="{StaticResource Surface1Brush}"
                        BorderThickness="1" Margin="0,0,12,0">
                    <Grid>
                        <Image Source="{Binding Icon}" Stretch="Uniform" Margin="7"
                               Visibility="{Binding Icon, Converter={StaticResource NullToVis}}" />
                        <TextBlock Text="EXT" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource MauveBrush}"
                                   Visibility="{Binding Icon, Converter={StaticResource NullToVis}, ConverterParameter=invert}" />
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Repo}" Style="{StaticResource MuteText}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding Stars}" Style="{StaticResource BadgeText}"
                           Foreground="{StaticResource YellowBrush}" VerticalAlignment="Top" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="8" Padding="9,4" Margin="0,0,8,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource SapphireSoftBrush}" />
                            <Setter Property="BorderBrush" Value="{StaticResource SapphireBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource GreenSoftBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource YellowSoftBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource YellowBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasAsset}" Value="False">
                                    <Setter Property="Background" Value="{StaticResource RedSoftBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource RedBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatusBadge}" Style="{StaticResource BadgeText}" />
                </Border>
                <TextBlock Grid.Column="1" Text="{Binding InstalledDetail}"
                           Style="{StaticResource MuteText}" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>

            <TextBlock Grid.Row="2" Text="{Binding Description}" Style="{StaticResource SubtleText}"
                       TextWrapping="Wrap" MaxHeight="58" TextTrimming="CharacterEllipsis" />

            <Grid Grid.Row="3" Margin="0,12,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding AssetSummary}"
                           Style="{StaticResource MuteText}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ReleaseSummary}"
                           Style="{StaticResource MuteText}" Margin="10,0,0,0" />
                <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" IsIndeterminate="True"
                             Margin="0,8,0,0" Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}" />
            </Grid>

            <TextBlock Grid.Row="4" Text="{Binding BusyMessage}"
                       Foreground="{StaticResource SapphireBrush}" FontSize="11" FontWeight="SemiBold"
                       Margin="0,0,0,8" Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}" />

            <Grid Grid.Row="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Row="0" Grid.Column="1" Content="{Binding InstallButtonLabel}"
                        Style="{StaticResource AccentButton}" Command="{Binding InstallCommand}"
                        IsEnabled="{Binding CanInstall}" MinWidth="96" Margin="0,0,6,0" />
                <Button Grid.Row="0" Grid.Column="2" Content="Uninstall" Style="{StaticResource DangerButton}"
                        Command="{Binding UninstallCommand}"
                        Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}" Margin="0,0,6,0" />
                <Button Grid.Row="0" Grid.Column="3" Content="Folder"
                        Command="{Binding OpenInstallDirCommand}" IsEnabled="{Binding CanOpenInstallDir}"
                        Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}" />
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                            Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,7,0,0">
                    <Button Content="Hide" Style="{StaticResource LinkButton}"
                            Command="{Binding HideRepositoryCommand}" Margin="0,0,4,0" />
                    <Button Content="Repo" Style="{StaticResource LinkButton}"
                            Command="{Binding OpenRepoCommand}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
