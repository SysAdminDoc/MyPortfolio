<UserControl x:Class="MyPortfolio.Chrome.Views.ChromeTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MyPortfolio.Chrome.ViewModels"
             xmlns:views="clr-namespace:MyPortfolio.Chrome.Views"
             xmlns:conv="clr-namespace:MyPortfolio.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:ChromeTabViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:EmptyStringToVisibilityConverter x:Key="EmptyStringToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource MantleBrush}"
                Padding="20,12" BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" MinWidth="320">
                    <TextBox x:Name="SearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Search Chrome extensions" Style="{StaticResource MuteText}"
                               Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                               Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource EmptyStringToVis}}" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding LastRefreshText, Mode=OneWay}"
                               Style="{StaticResource MuteText}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0" />

                    <CheckBox Grid.Column="1" Content="Installed only"
                              IsChecked="{Binding ShowInstalledOnly}"
                              VerticalAlignment="Center" Margin="18,0" />

                    <ComboBox Grid.Column="2" ItemsSource="{Binding Browsers}"
                              SelectedItem="{Binding SelectedBrowser}"
                              VerticalAlignment="Center" Width="180"
                              ToolTip="Browser used by 'Launch with extensions'" Margin="0,0,8,0" />

                    <Button Grid.Column="3" Content="Launch with extensions"
                            Command="{Binding LaunchBrowserCommand}"
                            IsEnabled="{Binding CanLaunchBrowser}"
                            Style="{StaticResource SuccessButton}" Margin="0,0,8,0" />

                    <Button Grid.Column="4" Content="Install folder"
                            Command="{Binding OpenInstallDirCommand}" Margin="0,0,8,0" />

                    <Button Grid.Column="5" Content="{Binding RefreshButtonLabel}"
                            Command="{Binding RefreshCommand}" Style="{StaticResource AccentButton}" />
                </Grid>

                <ProgressBar Grid.Row="2" IsIndeterminate="True" Margin="0,8,0,0"
                             Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,14,12,16">
                <ItemsControl ItemsSource="{Binding ExtensionsView}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:ExtensionCardView />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="520" Padding="24" Style="{StaticResource PanelBorder}"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding EmptyStateTitle}" Style="{StaticResource SectionTitle}" TextAlignment="Center" />
                    <TextBlock Text="{Binding EmptyStateMessage}" Style="{StaticResource SubtleText}"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,18" />
                    <Button Content="Refresh extensions" Command="{Binding RefreshCommand}"
                            Style="{StaticResource AccentButton}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
