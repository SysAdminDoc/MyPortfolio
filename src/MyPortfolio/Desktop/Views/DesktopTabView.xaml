<UserControl x:Class="MyPortfolio.Desktop.Views.DesktopTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MyPortfolio.Desktop.ViewModels"
             xmlns:views="clr-namespace:MyPortfolio.Desktop.Views"
             xmlns:conv="clr-namespace:MyPortfolio.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:DesktopTabViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:EmptyStringToVisibilityConverter x:Key="EmptyStringToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource MantleBrush}"
                Padding="20,12" BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" MinWidth="320">
                        <TextBox x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Search desktop apps, repositories, or descriptions"
                                   Style="{StaticResource MuteText}"
                                   Margin="12,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource EmptyStringToVis}}" />
                    </Grid>

                    <CheckBox Grid.Column="1" Content="Installed only"
                              IsChecked="{Binding ShowInstalledOnly}"
                              VerticalAlignment="Center" Margin="18,0" />

                    <TextBlock Grid.Column="2" Style="{StaticResource MuteText}" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Run Text="{Binding AvailableCount, Mode=OneWay}" />
                        <Run Text="apps •" />
                        <Run Text="{Binding InstalledCount, Mode=OneWay}" Foreground="{StaticResource GreenBrush}" />
                        <Run Text="installed" />
                    </TextBlock>

                    <Button Grid.Column="3" Content="Install folder"
                            Command="{Binding OpenInstallDirCommand}" Margin="0,0,8,0" />

                    <Button Grid.Column="4" Content="{Binding RefreshButtonLabel}"
                            Command="{Binding RefreshCommand}" Style="{StaticResource AccentButton}" />
                </Grid>

                <ProgressBar Grid.Row="1" IsIndeterminate="True" Margin="0,10,0,0"
                             Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,14,12,16">
                <ItemsControl ItemsSource="{Binding AppsView}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:AppCardView />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="520" Padding="24" Style="{StaticResource PanelBorder}"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding EmptyStateTitle}" Style="{StaticResource SectionTitle}" TextAlignment="Center" />
                    <TextBlock Text="{Binding EmptyStateMessage}" Style="{StaticResource SubtleText}"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,18" />
                    <Button Content="Refresh desktop apps" Command="{Binding RefreshCommand}"
                            Style="{StaticResource AccentButton}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
