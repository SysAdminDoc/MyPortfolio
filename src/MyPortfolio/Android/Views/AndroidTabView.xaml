<UserControl x:Class="MyPortfolio.Android.Views.AndroidTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MyPortfolio.Android.ViewModels"
             xmlns:views="clr-namespace:MyPortfolio.Android.Views"
             xmlns:conv="clr-namespace:MyPortfolio.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:AndroidTabViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:EmptyStringToVisibilityConverter x:Key="EmptyStringToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource MantleBrush}"
                Padding="20,12" BorderBrush="{DynamicResource Surface0Brush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" MinWidth="320">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Search Android apps, repositories, or descriptions"
                               Style="{StaticResource MuteText}"
                               Margin="12,0,0,0" VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Visibility="{Binding Text, ElementName=SearchBox, Converter={StaticResource EmptyStringToVis}}" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Style="{StaticResource MuteText}" VerticalAlignment="Center" Margin="0,0,16,0">
                        <Run Text="{Binding AvailableCount, Mode=OneWay}" />
                        <Run Text="apps •" />
                        <Run Text="{Binding DownloadedCount, Mode=OneWay}" Foreground="{DynamicResource GreenBrush}" />
                        <Run Text="downloaded •" />
                        <Run Text="{Binding LastRefreshText, Mode=OneWay}" />
                    </TextBlock>

                    <CheckBox Grid.Column="1" Content="Downloaded only"
                              IsChecked="{Binding ShowDownloadedOnly}"
                              VerticalAlignment="Center" Margin="18,0" />

                    <Button Grid.Column="2" Content="Open download folder"
                            Command="{Binding OpenDownloadFolderCommand}" Margin="0,0,8,0" />

                    <Button Grid.Column="3" Content="{Binding RefreshButtonLabel}"
                            Command="{Binding RefreshCommand}" Style="{StaticResource AccentButton}" />
                </Grid>

                <Grid Grid.Row="2" Margin="0,10,0,0"
                      Visibility="{Binding HasRefreshProgress, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ProgressBar Grid.Row="0"
                                 Minimum="0"
                                 Maximum="{Binding RefreshProgressMaximum}"
                                 Value="{Binding RefreshProgressValue}"
                                 IsIndeterminate="{Binding IsRefreshProgressIndeterminate}" />
                    <TextBlock Grid.Row="1" Text="{Binding RefreshProgressText}"
                               Style="{StaticResource MuteText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                </Grid>

                <Border Grid.Row="3" BorderBrush="{DynamicResource Surface0Brush}"
                        BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,10,0,0"
                        Visibility="{Binding HasDiscoveryDiagnostics, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding DiscoverySummary}" Style="{StaticResource MuteText}"
                                       TextWrapping="Wrap" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                                <Button Content="Copy diagnostics"
                                        Command="{Binding CopyDiagnosticsCommand}"
                                        Style="{StaticResource LinkButton}" Padding="8,2" MinHeight="24" />
                                <Button Content="Save diagnostics"
                                        Command="{Binding SaveDiagnosticsCommand}"
                                        Style="{StaticResource LinkButton}" Padding="8,2" MinHeight="24" Margin="4,0,0,0"
                                        ToolTip="Save a redacted diagnostics text file and reveal it in Explorer" />
                                <Button Content="{Binding DiscoveryDetailsButtonText}"
                                        Command="{Binding ToggleDiscoveryDetailsCommand}"
                                        Style="{StaticResource LinkButton}" Padding="8,2" MinHeight="24" Margin="4,0,0,0"
                                        Visibility="{Binding HasOwnerDiagnostics, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding DiscoveryWarningText}" Foreground="{DynamicResource YellowBrush}"
                                   FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Visibility="{Binding HasDiscoveryWarning, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding RateLimitText}" Style="{StaticResource MuteText}"
                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                   Visibility="{Binding HasRateLimitText, Converter={StaticResource BoolToVis}}" />
                        <ScrollViewer MaxHeight="190" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0"
                                      Visibility="{Binding ShowDiscoveryDetails, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding OwnerDiagnostics}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource CrustBrush}"
                                                BorderBrush="{DynamicResource Surface0Brush}"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="10,8" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Owner}"
                                                           FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding StatusText}"
                                                           Style="{StaticResource MuteText}" FontWeight="SemiBold" Margin="12,0,0,0" />
                                                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding MatchDetailText}"
                                                           Style="{StaticResource MuteText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                                <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,6,0,0">
                                                    <TextBlock Text="{Binding SkipDetailText}" Style="{StaticResource MuteText}" Margin="0,0,14,0" />
                                                    <TextBlock Text="{Binding CacheDetailText}" Style="{StaticResource MuteText}" Margin="0,0,14,0" />
                                                    <TextBlock Text="{Binding ProbeDetailText}" Style="{StaticResource MuteText}" />
                                                </WrapPanel>
                                                <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding ErrorMessage}"
                                                           Foreground="{DynamicResource YellowBrush}" FontSize="11"
                                                           FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,0"
                                                           Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVis}}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource CrustBrush}"
                BorderBrush="{DynamicResource Surface0Brush}" BorderThickness="0,0,0,1"
                Padding="20,8">
            <TextBlock Style="{StaticResource MuteText}" TextWrapping="Wrap">
                <Run Text="Android tab is download-only — APKs land in" />
                <Run Text="{Binding DownloadFolder, Mode=OneWay}" Foreground="{DynamicResource TealBrush}" FontWeight="SemiBold" />
                <Run Text=". Sideload onto a device with adb install or your own Files transfer." />
            </TextBlock>
        </Border>

        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,14,12,16">
                <ItemsControl ItemsSource="{Binding AppsView}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:AndroidAppCardView />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="520" Padding="24" Style="{StaticResource PanelBorder}"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding EmptyStateTitle}" Style="{StaticResource SectionTitle}" TextAlignment="Center" />
                    <TextBlock Text="{Binding EmptyStateMessage}" Style="{StaticResource SubtleText}"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,18" />
                    <Button Content="Refresh Android apps" Command="{Binding RefreshCommand}"
                            Style="{StaticResource AccentButton}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
